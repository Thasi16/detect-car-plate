from ultralytics import YOLO

# Load model pretrained
model = YOLO("yolov8s.pt")

# Train với Multi-GPU
model.train(
    data=r"/kaggle/input/datasets/lduythi/dataset-cha/data.yaml",
    epochs=200,
    imgsz=320,
    batch=32,          
    device=[0, 1],     
    workers=8,
    project="Plate_OCR",
    name="yolov8s_char"
)
